<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h3 class="mb-10 font-semibold px-2 text-3xl">Login Your Account</h3>
        <form method="post" action="/login">
           
            <input class="px-3 py-2 rounded-md bg-transparent border border-zinc-800 outline-none" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded-md bg-transparent border border-zinc-800 outline-none" type="password" placeholder="password" name="password">
          
            <input type="submit" value="Login" class="bg-blue-500 px-5 py-2 rounded-md">
        </form>
    </div>
</body>
</html>